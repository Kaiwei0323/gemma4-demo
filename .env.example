HOST=127.0.0.1
PORT=3003
API_BASE_URL=http://99.64.152.85:5000
# Docker Compose: HOST + PORT also set the default PUBLIC_URL in logs (browser host + published port).
# Optional override:
# PUBLIC_URL=http://example.com:3003

# Docker Compose Postgres (used to build DATABASE_URL for the app: postgres://USER:PASSWORD@db:5432/DB)
# Password is fixed on first volume init; if you change it later, run: docker compose down -v
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gemma4_database
# Set to 1 on the app container to skip applying sql/*.sql on startup (Docker image entrypoint).
# SKIP_DB_MIGRATE=1

# Local Postgres auth (npm run dev on the host only; not used for Compose DATABASE_URL)
# Example:
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/gemma4_demo
DATABASE_URL=
# Used to sign session cookies (set to a long random string)
SESSION_SECRET=

